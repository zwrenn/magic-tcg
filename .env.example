# --- Neon Postgres ---
# Create a project at https://neon.tech, then copy the "pooled" connection
# string from the dashboard (Connection Details -> "Pooled connection").
# It looks like: postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# --- App passphrase gate ---
# A single shared secret everyone in the pod types once. Keeps the site from
# being fully public. Pick anything; share it with the four of you.
POD_PASSPHRASE=changeme
